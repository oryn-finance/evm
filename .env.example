# Deployer private key (with testnet gas on each chain). Never commit .env.
PRIVATE_KEY=0x...

# Address that will own the EscrowFactory (e.g. your multisig or EOA)
OWNER_ADDRESS=0x...

# Optional: for --verify. Get keys from Etherscan, Basescan, Arbiscan, Snowtrace, Moonscan per chain.
# ETHERSCAN_API_KEY=
# BASESCAN_API_KEY=
# ARBISCAN_API_KEY=
# SNOWTRACE_API_KEY=
# MOONSCAN_API_KEY=

# Optional: set before each deploy or use --rpc-url in the command
# ETH_RPC_URL=https://rpc.sepolia.org

# ── TestFullFlow script (Avax Fuji) ──
ESCROW_FACTORY=0xFec9bD7fC73526c45369D13a8a73B56bB69d8e5C
TOKEN_ADDRESS=0x...
RECIPIENT_ADDRESS=0x...
# ESCROW_AMOUNT=1000000
# AVAX_FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc

# ═══════════════════════════════════════════════════════════════
# ICTT (Interchain Token Transfer) — set per-token, per-chain
# ═══════════════════════════════════════════════════════════════

# ── Chain RPCs ──
# RPC_URL_HOME=https://api.avax-test.network/ext/bc/C/rpc
# RPC_URL_REMOTE=https://subnets.avax.network/echo/testnet/rpc

# ── Step 1: DeployBridgeableERC20 (home chain) ──
# TOKEN_NAME="USD Coin"
# TOKEN_SYMBOL="USDC"
# TOKEN_DECIMALS=6
# INITIAL_SUPPLY=1000000000000        # raw units (e.g. 1M USDC = 1e12 with 6 decimals)

# ── Teleporter infra (must exist on BOTH chains before Steps 2-4) ──
# TELEPORTER_VERSION=v0.2.0
# TELEPORTER_REGISTRY_ADDRESS=0x...   # TeleporterRegistry (NOT TeleporterMessenger)
# TELEPORTER_MANAGER_ADDRESS=0x...    # owner EOA or multisig
# MIN_TELEPORTER_VERSION=1

# ── Step 2: DeployERC20TokenHome (home chain) ──
# TOKEN_ADDRESS=0x...                 # BridgeableERC20 from Step 1

# ── Step 3: DeployERC20TokenRemote (remote chain) ──
# TOKEN_HOME_BLOCKCHAIN_ID=0x...      # home chain blockchain ID (bytes32, 0x + 64 hex)
# TOKEN_HOME_ADDRESS=0x...            # ERC20TokenHome from Step 2
# TOKEN_HOME_DECIMALS=6
# REMOTE_TOKEN_NAME="Bridged USDC"
# REMOTE_TOKEN_SYMBOL="bUSDC"
# REMOTE_TOKEN_DECIMALS=6

# ── Step 4: RegisterRemoteWithHome (remote chain) ──
# TOKEN_REMOTE_ADDRESS=0x...          # ERC20TokenRemote from Step 3
# FEE_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
# FEE_AMOUNT=0

# ═══════════════════════════════════════════════════════════════
# Phase 4 — Avalanche Escrow + ICTT Bridge
# ═══════════════════════════════════════════════════════════════

# ── Chain RPCs ──
# RPC_URL_CCHAIN=https://api.avax-test.network/ext/bc/C/rpc
# RPC_URL_L1=https://subnets.avax.network/echo/testnet/rpc

# ── Blockchain IDs (bytes32, 0x + 64 hex chars) ──
# Get via: cast call <TokenHome_or_TokenRemote> "getBlockchainID()" --rpc-url <RPC>
# CCHAIN_BLOCKCHAIN_ID=0x...
# L1_BLOCKCHAIN_ID=0x...

# ── Deployed contract addresses (from Phase 4 outputs) ──
# AVALANCHE_FACTORY_CCHAIN=0x...      # AvalancheEscrowFactory on C-chain
# BRIDGE_FACTORY_CCHAIN=0x...         # ICMBridgeFactory on C-chain
# AVALANCHE_FACTORY_L1=0x...          # AvalancheEscrowFactory on L1
# BRIDGE_FACTORY_L1=0x...             # ICMBridgeFactory on L1

# ── Route registration (per token) ──
# TOKEN_ADDRESS=0x...                 # ERC20 on C-chain (e.g. WBTC)
# TOKEN_HOME_ADDRESS=0x...            # ERC20TokenHome on C-chain
# TOKEN_REMOTE_ADDRESS=0x...          # ERC20TokenRemote on L1 (wrapped token)
# REQUIRED_GAS_LIMIT=250000           # ICM relayer gas limit for delivery
